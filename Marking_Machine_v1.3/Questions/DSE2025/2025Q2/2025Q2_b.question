<\begin{Question_en}>
	(b) What is the kinetic energy of the bead at its maximum height?
<\end{Question_en}>


<\begin{Question_zh}>
	
<\end{Question_zh}>

<\begin{Mark}>
	2
<\end{Mark}>


<\begin{Answer}>
	[
	KE = \frac{1}{2}mv^2 ,
	KE = \frac{1}{2} \times 0.01 \times (*v_t*)^2,
	]
<\end{Answer}>

